rules_version = '2';

// ============================================================
//  أعمالي ERP — Firestore Security Rules
//  Per-account isolation: every account's data lives under
//  /accounts/{uid}/...  and is ONLY readable/writable by that
//  same authenticated user. No account can ever see or modify
//  another account's products / customers / invoices / employees.
// ============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ---- Helpers ----
    function isSignedIn() {
      return request.auth != null;
    }
    function isAccountOwner(accountId) {
      return isSignedIn() && request.auth.uid == accountId;
    }

    // ---- Per-account subtree ----
    match /accounts/{accountId}/{document=**} {
      allow read, write: if isAccountOwner(accountId);
    }

    match /accounts/{accountId} {
      allow read, write: if isAccountOwner(accountId);
    }

    // ---- User profiles ----
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // ---- Everything else is denied by default ----
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
